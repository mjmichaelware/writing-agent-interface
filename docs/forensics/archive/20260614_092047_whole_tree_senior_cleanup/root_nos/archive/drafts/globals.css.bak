@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  /* Layer 0 palette */
  --bg-void: #0a0a0a;
  --text-body: #e8e4dc;
  --text-muted: #8a857c;
  --accent-gold: #c9a96e;
  --accent-amber: #d4a574;
  --sacred: #e8d4a0;
  --descent: #6b2c2c;

  /* Typography */
  --font-prose:
    "EB Garamond",
    "Cormorant Garamond",
    "Spectral",
    Georgia,
    serif;

  --font-title:
    var(--font-hebrew),
    "EB Garamond",
    serif;

  --leading-prose: 1.7;
}

html,
body {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
  background-color: var(--bg-void);
  color: var(--text-body);
}

body {
  font-family: var(--font-prose);
}

/* Kinetic typography */
.kinetic-token {
  display: inline;
  white-space: pre-wrap;
  position: relative;

  font-weight: calc(400 + (var(--arc-mass, 0) * 500));

  text-shadow:
    0
    calc(var(--arc-mass, 0) * 8px)
    calc(var(--arc-mass, 0) * 12px)
    rgba(0, 0, 0, 0.9);

  letter-spacing: calc(var(--arc-tension, 0) * -0.12em);

  transform:
    scaleX(calc(1 - (var(--arc-tension, 0) * 0.15)));

  top: calc(var(--arc-velocity, 0) * -8px);

  transition:
    font-weight 0.4s cubic-bezier(0.16, 1, 0.3, 1),
    text-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
    letter-spacing 0.4s cubic-bezier(0.16, 1, 0.3, 1),
    transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
    top 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Paragraph structure */
.manuscript-paragraph-segment {
  margin-bottom: 2.5rem;
  text-align: justify;
  text-justify: inter-word;
  line-height: var(--leading-prose);
  font-family: var(--font-prose);
  will-change: transform, opacity;
}

/* Drop cap */
.manuscript-paragraph-segment:first-of-type::first-letter {
  float: left;
  font-size: 3.5rem;
  line-height: 1;
  padding-top: 4px;
  padding-right: 8px;
  padding-left: 2px;
  font-weight: 900;
  color: var(--sacred);
}

/* Buttons */
.primary-button {
  font-family: var(--font-prose);
  font-size: 1.125rem;
  color: var(--text-body);
  border: 1px solid var(--text-muted);
  background: transparent;
  padding: 0.75rem 2rem;
  transition: all 0.5s ease;
  cursor: pointer;
}

.primary-button:hover {
  border-color: var(--accent-gold);
  color: var(--accent-gold);

  box-shadow:
    0 0 15px rgba(201, 169, 110, 0.15);
}

.section-label {
  font-family: var(--font-prose);
  font-variant: small-caps;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}

/* Title-page text links */
.nav-link {
  font-family: var(--font-prose);
  font-variant: small-caps;
  font-size: 1rem;
  letter-spacing: 0.04em;
  color: var(--text-muted);
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0.4rem 0;
  position: relative;
  transition: color 0.4s ease;
}
.nav-link:hover { color: var(--text-body); }
.nav-link::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 0;
  height: 1px;
  width: 0%;
  background-color: var(--accent-gold);
  transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}
.nav-link:hover::after { width: 100%; }
.nav-link:disabled { opacity: 0.3; cursor: default; }
.nav-link:disabled:hover::after { width: 0; }

/* Table of Contents */
.toc-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  width: 100%;
  padding: 1rem 0;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(232, 228, 220, 0.08);
  text-align: left;
  cursor: pointer;
  position: relative;
  transition: padding-left 0.4s ease;
}
.toc-row::before {
  content: '';
  position: absolute;
  left: -0.75rem;
  top: 15%;
  bottom: 15%;
  width: 2px;
  background-color: var(--accent-gold);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.toc-row:hover { padding-left: 0.5rem; }
.toc-row:hover::before { transform: scaleY(1); }
.toc-title {
  font-family: var(--font-prose);
  font-size: 1.15rem;
  color: var(--text-muted);
  transition: color 0.4s ease;
}
.toc-row:hover .toc-title { color: var(--text-body); }
.toc-numeral {
  font-family: var(--font-prose);
  font-style: italic;
  font-size: 0.95rem;
  color: var(--text-muted);
  opacity: 0.6;
  transition: color 0.4s ease, opacity 0.4s ease;
}
.toc-row:hover .toc-numeral {
  color: var(--accent-gold);
  opacity: 1;
}
.toc-pending {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  width: 100%;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(232, 228, 220, 0.08);
  opacity: 0.35;
  cursor: default;
}
.toc-pending .toc-title { font-style: italic; }
.toc-part-heading {
  font-family: var(--font-prose);
  font-variant: small-caps;
  font-size: 1.05rem;
  letter-spacing: 0.06em;
  color: var(--text-body);
  text-align: center;
  margin-top: 3rem;
  margin-bottom: 1.5rem;
}
